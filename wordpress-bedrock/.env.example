# Database
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=change-this-password
DB_ROOT_PASSWORD=change-this-root-password

# Bedrock environment
WP_ENV=development
WP_HOME=http://yoursite.example.com
WP_SITEURL=${WP_HOME}/wp

# Salts - generate at https://roots.io/salts.html
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# SSH Keys (raw URL to a file with one public key per line)
SSH_KEYS_URL=
# Optional: Token for private GitLab/GitHub repos (GitLab PAT with read_repository scope)
SSH_KEYS_TOKEN=
